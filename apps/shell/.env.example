# ── PropSim Engine ──
NEXT_PUBLIC_PROPSIM_BASE_URL=http://localhost:3000
PROPSIM_BASE_URL=http://localhost:3000
PROPSIM_SHELL_JWT_SECRET=changeme_local_dev

# ── Solana ──
NEXT_PUBLIC_SOLANA_RPC_URL=http://localhost:8899
NEXT_PUBLIC_SOLANA_CLUSTER=localnet

# ── USDC Mint (create with `pnpm usdc:mint` for localnet) ──
NEXT_PUBLIC_USDC_MINT=<USDC_MINT_PUBKEY_LOCALNET_OR_MAINNET>

# ── Treasury / Profit Wallets ──
NEXT_PUBLIC_TREASURY_WALLET=<PUBLIC_TREASURY_PUBKEY>
NEXT_PUBLIC_PROFIT_WALLET=<PUBLIC_PROFIT_PUBKEY>

# ── Vault Program (deployed with `pnpm vault:deploy`) ──
NEXT_PUBLIC_VAULT_PROGRAM_ID=<DEPLOYED_VAULT_PROGRAM_ID>
NEXT_PUBLIC_VAULT_CONFIG_PDA=<DERIVED_CONFIG_PDA>
NEXT_PUBLIC_VAULT_USDC_TOKEN_ACCOUNT=<VAULT_USDC_ATA>

# ── Server-only claim signing key (base64 encoded 64-byte Ed25519 secret key) ──
PROPSIM_CLAIM_SIGNER_ED25519_PRIVATE_KEY_BASE64=<SERVER_ONLY_PRIVATE_KEY_BASE64>

# ── Claim Settings ──
CLAIM_DOMAIN=PROPSIM_PAYOUT_V1
CLAIM_TTL_SECONDS=604800
DAILY_CAP_USDC=5000

{
  "name": "auto-prop-firm",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "solana:localnet": "solana-test-validator --reset",
    "vault:build": "cd programs/propsim_vault && anchor build",
    "vault:deploy": "bash scripts/deploy-vault.sh",
    "usdc:mint": "bash scripts/mint-usdc.sh",
    "test:vault": "cd programs/propsim_vault && anchor test",
    "db:push": "cd apps/shell && npx prisma db push",
    "db:studio": "cd apps/shell && npx prisma studio"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.91.0",
    "@solana/spl-token": "^0.4.0",
    "borsh": "^2.0.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "chai": "^4.4.0",
    "mocha": "^10.4.0",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.0"
  },
  "packageManager": "pnpm@9.0.0"
}
